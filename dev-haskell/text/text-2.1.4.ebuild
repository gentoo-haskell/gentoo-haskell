EAPI=8

# ebuild generated by hackport 0.9.1.0.9999
#hackport: flags: -bytestring-builder,-developer,-integer-simple

CABAL_FEATURES="lib profile haddock hoogle hscolour" # circular deps in test-suite
# break circular dependencies:
# https://github.com/gentoo-haskell/gentoo-haskell/issues/810
CABAL_FEATURES+=" nocabaldep"
inherit haskell-cabal

DESCRIPTION="An efficient packed Unicode text type"
HOMEPAGE="https://github.com/haskell/text"

LICENSE="BSD-2"
SLOT="0/${PV}"
KEYWORDS="~amd64"
IUSE="extendedbenchmarks pure-haskell +simdutf"

# break cyclic dependencies:
RESTRICT=test

RDEPEND=">=dev-haskell/data-array-byte-0.1:=[profile?] <dev-haskell/data-array-byte-0.2:=[profile?]
	>=dev-lang/ghc-9.0.2:=
	!pure-haskell? ( simdutf? ( || ( llvm-core/clang
						sys-devel/gcc[cxx] ) ) )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-3.4.1.0
"
#	test? ( >=dev-haskell/quickcheck-2.12.6 <dev-haskell/quickcheck-2.18
#		dev-haskell/tasty
#		dev-haskell/tasty-hunit
#		dev-haskell/tasty-inspection-testing
#		dev-haskell/tasty-quickcheck
#		dev-haskell/temporary )

src_configure() {
	haskell-cabal_src_configure \
		--flag=-bytestring-builder \
		--flag=-developer \
		$(cabal_flag extendedbenchmarks extendedbenchmarks) \
		--flag=-integer-simple \
		$(cabal_flag pure-haskell pure-haskell) \
		$(cabal_flag simdutf simdutf)
}

CABAL_CORE_LIB_GHC_PV="9.12.4"
